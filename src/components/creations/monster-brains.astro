---
import FlipCreation from "../flip-creation.astro";

import glitterSlime from "@/assets/images/creations/monster-explosions.png";

type Props = {
  flippable?: boolean;
};

const { flippable = true } = Astro.props;
---

<FlipCreation
  flippable={flippable}
  image={glitterSlime}
  text={["Monster Explosions"]}
  color="green"
/>
