---
import calendarIconSvg from "@/assets/images/pages/little-learners/schedule-icons/calendar.svg?raw";
import LittleLearnersTimeSlot from "@/components/little-learners-time-slot.astro";

type SlotIcon =
  | "welcome"
  | "craft"
  | "tea"
  | "science"
  | "movement"
  | "story"
  | "pickup";

type Props = {
  day: string;
  timeRange: string;
  headerStart: string;
  headerEnd: string;
  calendarColor: string;
  slots: readonly {
    time: string;
    title: string;
    subtitle?: string;
    color: string;
    icon: SlotIcon;
  }[];
};

const { day, timeRange, headerStart, headerEnd, calendarColor, slots } =
  Astro.props;

const calendarIconMarkup = calendarIconSvg
  .replace("<svg ", '<svg class="h-full w-full" ')
  .replaceAll("#8F44E1", calendarColor);
---

<div
  class="overflow-hidden rounded-[2rem] bg-white shadow-[0_0_32px_rgba(143,68,225,0.08)]"
>
  <div
    class="flex flex-col gap-4 p-5 md:flex-row md:items-center md:gap-6 md:p-8"
    style={{
      background: `linear-gradient(90deg, ${headerStart}, ${headerEnd})`,
    }}
  >
    <div
      class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-white md:h-24 md:w-24"
    >
      <div class="h-10 w-10 md:h-12 md:w-12">
        <Fragment set:html={calendarIconMarkup} />
      </div>
    </div>

    <div>
      <p
        class="font-gotham text-xl font-bold leading-none text-white md:text-[2rem]"
      >
        {day} Sessions
      </p>
      <div
        class="mt-3 inline-flex rounded-full bg-white/15 px-5 py-2 font-gotham text-base font-bold text-white md:px-7 md:text-[1.5rem]"
      >
        {timeRange}
      </div>
    </div>
  </div>

  <div class="bg-white px-4 py-5 md:px-6 md:py-6">
    <div>
      {
        slots.map((slot, index) => (
          <LittleLearnersTimeSlot
            time={slot.time}
            title={slot.title}
            subtitle={slot.subtitle}
            color={slot.color}
            icon={slot.icon}
            isFirst={index === 0}
            isLast={index === slots.length - 1}
          />
        ))
      }
    </div>
  </div>
</div>
